# ─── Covenant Trigger Oracle — Environment Variables ─────────────────────────

# Ed25519 private key for the oracle wallet (hex, with or without 0x prefix).
# This key ONLY pays gas — execute_trigger is permissionless.
# Generate with: aptos key generate --key-scheme ed25519
ORACLE_PRIVATE_KEY=0x<your_oracle_ed25519_private_key>

# Deployed covenant::escrow module address on Aptos.
CONTRACT_ADDRESS=0x<deployed_contract_address>

# Aptos fullnode RPC endpoint.
# Mainnet : https://fullnode.mainnet.aptoslabs.com/v1
# Testnet : https://fullnode.testnet.aptoslabs.com/v1
# Devnet  : https://fullnode.devnet.aptoslabs.com/v1
APTOS_NODE_URL=https://fullnode.mainnet.aptoslabs.com/v1

# Optional: comma-separated agreement IDs to watch immediately on first start.
# The oracle auto-discovers all new agreements by probing IDs sequentially,
# but SEED_AGREEMENT_IDS lets you backfill agreements created before the oracle
# was deployed. Leave empty to start from ID 1 automatically.
# Example: SEED_AGREEMENT_IDS=1,2,5
SEED_AGREEMENT_IDS=

# How often to check on-chain state (milliseconds).
# Default: 300000 (5 minutes). Minimum recommended: 60000 (1 minute).
POLL_INTERVAL_MS=300000

# Set to "true" to log trigger detections without submitting transactions.
# Useful for validating configuration before going live.
DRY_RUN=false

# Path to the JSON state file used to persist cursor and watch list across
# restarts. Default: ./data/state.json (relative to working directory).
# When running in Docker, mount a volume at /app/packages/oracle/data.
STATE_FILE=./data/state.json
