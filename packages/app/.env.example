# ── Aptos contract ────────────────────────────────────────────────────────────
# Deployed VaultLayer escrow module address.
NEXT_PUBLIC_CONTRACT_ADDRESS=0xCAFE

# Aptos fullnode RPC. Change to testnet for development.
# Testnet: https://fullnode.testnet.aptoslabs.com/v1
NEXT_PUBLIC_APTOS_NODE_URL=https://fullnode.mainnet.aptoslabs.com/v1

# "mainnet" | "testnet" | "devnet"
NEXT_PUBLIC_APTOS_NETWORK=mainnet

# ── Shelby service account (server-side only) ─────────────────────────────────
# Optional: hex Ed25519 private key for a read-only Shelby service account.
# Used by the /api/meta API route to fetch __meta blobs for buyer verification.
# If omitted, buyers must paste the __meta JSON manually.
SHELBY_SERVICE_PRIVATE_KEY=
